APP_PORT=8090

SPRING_DATASOURCE_URL=jdbc:postgresql://host.docker.internal:5432/credittracker
SPRING_DATASOURCE_USERNAME=credittracker
SPRING_DATASOURCE_PASSWORD=replace-with-a-strong-password

APP_AUTH_GOOGLE_ENABLED=false
APP_ADMIN_SEED_EMAIL=admin@example.com
APP_LOCAL_ADMIN_EMAIL=admin@example.com
APP_LOCAL_ADMIN_PASSWORD=replace-with-a-strong-local-password
APP_TIME_ZONE=America/Los_Angeles

APP_JWT_ISSUER=Prepaid Credit Tracker
APP_JWT_SECRET=replace-with-at-least-32-random-bytes
APP_AES_KEY_BASE64=replace-with-base64-encoded-32-byte-key
APP_MFA_ISSUER=Prepaid Credit Tracker
APP_PUBLIC_BASE_URL=https://app.example.com
APP_MAIL_FROM=no-reply@example.com

# Optional SMTP settings for password reset emails.
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
